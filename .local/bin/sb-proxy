#!/usr/bin/env python3

import argparse
import json
import tempfile
import subprocess
import sys
import shutil
import os


def prepare_config(config_template_path, local_port):
    with open(config_template_path) as file:
        config = json.loads(file.read())

    config["inbounds"] = [
        {
            "type": "socks",
            "tag": "socks-in",
            "listen": "127.0.0.1",
            "listen_port": local_port,
        }
    ]

    return config


def main():
    parser = argparse.ArgumentParser(description="Spin up a local SOCKS5 proxy using sing-box from a config template.")
    parser.add_argument("template", help="Config template for sing-box")
    parser.add_argument("-p", "--port", type=int, default=12334, help="Local SOCKS5 port (default: 12334)")
    args = parser.parse_args()

    if not shutil.which("sing-box"):
        print("Error: sing-box binary not found in PATH. Make sure it's installed.")
        sys.exit(1)

    config_data = prepare_config(args.template, args.port)

    # Write to a temporary file
    with tempfile.NamedTemporaryFile(mode="w", suffix=".json", delete=False) as tmp:
        json.dump(config_data, tmp, indent=2)
        tmp_path = tmp.name

    print(f"[*] Built proxy blueprint at {tmp_path}")
    print(f"[*] Starting local SOCKS5 proxy on 127.0.0.1:{args.port}...")
    print("[*] Press Ctrl+C to kill the connection.\n")

    try:
        # Pass control over to sing-box
        subprocess.run(["sing-box", "run", "-c", tmp_path])
    except KeyboardInterrupt:
        print("\n[*] Shutting down routing core...")
    finally:
        # Nuke the config file so we don't leak credentials or clutter /tmp
        if os.path.exists(tmp_path):
            os.remove(tmp_path)
            print("[*] Cleaned up temporary config.")


if __name__ == "__main__":
    main()
