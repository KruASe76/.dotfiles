#!/usr/bin/env python3

import argparse
import urllib.parse
import json
import tempfile
import subprocess
import sys
import shutil
import os


def parse_vless(uri, local_port):
    parsed = urllib.parse.urlparse(uri)
    if parsed.scheme != "vless":
        print("Error: Feed me a valid vless:// URI.")
        sys.exit(1)

    qs = urllib.parse.parse_qs(parsed.query)

    # Build the core outbound config
    outbound = {
        "type": "vless",
        "tag": "vless-out",
        "server": parsed.hostname,
        "server_port": parsed.port or 443,
        "uuid": parsed.username,
    }

    # Handle flow (typically xtls-rprx-vision)
    flow = qs.get("flow", [""])[0]
    if flow:
        outbound["flow"] = flow

    # Handle TLS / REALITY
    security = qs.get("security", [""])[0]
    if security in ["tls", "reality"]:
        tls = {
            "enabled": True,
            "server_name": qs.get("sni", [""])[0],
            "utls": {
                "enabled": True,
                "fingerprint": qs.get("fp", ["chrome"])[0]
            }
        }
        if security == "reality":
            tls["reality"] = {
                "enabled": True,
                "public_key": qs.get("pbk", [""])[0],
                "short_id": qs.get("sid", [""])[0]
            }
        outbound["tls"] = tls

    # Assemble the full blueprint
    config = {
        "log": {"level": "info"},
        "inbounds": [
            {
                "type": "socks",
                "tag": "socks-in",
                "listen": "127.0.0.1",
                "listen_port": local_port
            }
        ],
        "outbounds": [outbound]
    }

    return config


def main():
    parser = argparse.ArgumentParser(description="Spin up a local SOCKS5 proxy from a VLESS Reality link using sing-box.")
    parser.add_argument("uri", help="The vless:// URI string")
    parser.add_argument("-p", "--port", type=int, default=12334, help="Local SOCKS5 port (default: 12334)")
    args = parser.parse_args()

    if not shutil.which("sing-box"):
        print("Error: sing-box binary not found in PATH. Make sure it's installed.")
        sys.exit(1)

    config_data = parse_vless(args.uri, args.port)

    # Write to a temporary file
    with tempfile.NamedTemporaryFile(mode="w", suffix=".json", delete=False) as tmp:
        json.dump(config_data, tmp, indent=2)
        tmp_path = tmp.name

    print(f"[*] Built proxy blueprint at {tmp_path}")
    print(f"[*] Starting local SOCKS5 proxy on 127.0.0.1:{args.port}...")
    print("[*] Press Ctrl+C to kill the connection.\n")

    try:
        # Pass control over to sing-box
        subprocess.run(["sing-box", "run", "-c", tmp_path])
    except KeyboardInterrupt:
        print("\n[*] Shutting down routing core...")
    finally:
        # Nuke the config file so we don't leak credentials or clutter /tmp
        if os.path.exists(tmp_path):
            os.remove(tmp_path)
            print("[*] Cleaned up temporary config.")


if __name__ == "__main__":
    main()
